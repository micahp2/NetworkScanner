<Application x:Class="NetworkScanner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Default light mode colors -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBrush" Color="#F5F5F5" />
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0" />
        <SolidColorBrush x:Key="TextBrush" Color="#000000" />
        <SolidColorBrush x:Key="GridBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="GridTextBrush" Color="#000000" />
        <SolidColorBrush x:Key="GridAlternatingBrush" Color="#F5F5F5" />
        <SolidColorBrush x:Key="GridHeaderBrush" Color="#E0E0E0" />
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="InputTextBrush" Color="#000000" />
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#000000" />
        <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#E0E0E0" />
        <SolidColorBrush x:Key="ButtonTextBrush" Color="#000000" />
        
        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ButtonTextBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
