<Window x:Class="NetworkScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NetworkScanner"
        Title="Network Scanner" Height="700" Width="1100" MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Foreground="{DynamicResource TextBrush}"
        Background="{DynamicResource PanelBrush}"
        Icon="Assets/app_icon.ico">
    <Grid Background="{DynamicResource PanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- toolbar -->
            <RowDefinition Height="*" MinHeight="300" />   <!-- grid -->
            <RowDefinition Height="Auto" />   <!-- status -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,7">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- IP Range -->
                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="IP Range" FontSize="10" Margin="0,0,0,2"
                               Foreground="{DynamicResource HeaderTextBrush}" />
                    <ComboBox x:Name="RangesText" Width="250" Height="24" IsEditable="True"
                              VerticalContentAlignment="Center" FontSize="11">
                        <ComboBox.ToolTip>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Text="IP Range formats" Margin="0,0,0,5"/>
                                    <TextBlock FontFamily="Consolas" Text="192.168.1.0/24              IPv4 CIDR" />
                                    <TextBlock FontFamily="Consolas" Text="192.168.1.1-254             IPv4 last-octet range" />
                                    <TextBlock FontFamily="Consolas" Text="fe80::/120                  IPv6 CIDR (range /112 to /128)" />
                                    <TextBlock FontFamily="Consolas" Text="fe80::1-fe80::ff            IPv6 range (varies last 32 bits)" />
                                    <TextBlock FontFamily="Consolas" Text="192.168.1.100 / fe80::1     Single host (IPv4 or IPv6)" Margin="0,0,0,4"/>
                                    <TextBlock FontWeight="SemiBold" Text="Multiple ranges (comma-separated):" Margin="0,0,0,3"/>
                                    <TextBlock FontFamily="Consolas" Text="192.168.2.0/24, 192.168.4.0/24" />
                                    <TextBlock FontFamily="Consolas" Text="fe80::/120, 192.168.1.0/24" Margin="0,0,0,5"/>
                                    <TextBlock Foreground="Gray" FontSize="10" MaxWidth="300" TextWrapping="Wrap"
                                               Text="Ranges can also be entered one per line. All ranges are scanned in parallel." />
                                </StackPanel>
                            </ToolTip>
                        </ComboBox.ToolTip>
                    </ComboBox>
                </StackPanel>

                <!-- Ports -->
                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Ports" FontSize="10" Margin="0,0,0,2"
                               Foreground="{DynamicResource HeaderTextBrush}" />
                    <TextBox x:Name="PortsText" Width="210" Height="24" Padding="6,3"
                             VerticalContentAlignment="Center" FontSize="11">
                        <TextBox.ToolTip>
                            <ToolTip>
                                <StackPanel>
                                    <TextBlock FontWeight="Bold" Text="Port formats" Margin="0,0,0,5"/>
                                    <TextBlock FontFamily="Consolas" Text="22                 single port" />
                                    <TextBlock FontFamily="Consolas" Text="22,80,443          comma-separated" />
                                    <TextBlock FontFamily="Consolas" Text="8080-8090          range" />
                                    <TextBlock FontFamily="Consolas" Text="22,80,8080-8090    mixed" Margin="0,0,0,5"/>
                                    <TextBlock Foreground="Gray" FontSize="10" MaxWidth="260" TextWrapping="Wrap"
                                               Text="Common: 22=SSH  53=DNS  80=HTTP  443=HTTPS  3306=MySQL  8080/8443=HTTP-alt" />
                                </StackPanel>
                            </ToolTip>
                        </TextBox.ToolTip>
                    </TextBox>
                </StackPanel>

                <!-- Options Button + Popup -->
                <Button x:Name="OptionsButton" Content="Options" Width="60" Height="24"
                        FontSize="11" Click="OptionsButton_Click" VerticalAlignment="Bottom"
                        Margin="0,0,12,0" ToolTip="Configure scan and view options" />
                <Popup x:Name="OptionsPopup"
                       PlacementTarget="{Binding ElementName=OptionsButton}"
                       Placement="Bottom"
                       StaysOpen="True"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Padding="12"
                            CornerRadius="4">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Opacity="0.25"
                                              ShadowDepth="2" Direction="270" />
                        </Border.Effect>
                        <StackPanel>
                            <CheckBox x:Name="ScanIPv6Check" Content="Scan IPv6" FontSize="11" IsChecked="False"
                                      Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6"
                                      ToolTip="Enable IPv6 address scanning and auto-discovery of IPv6 neighbors." />
                            <CheckBox x:Name="ShowOfflineCheck" Content="Show Offline Devices" FontSize="11" IsChecked="True"
                                      Foreground="{DynamicResource TextBrush}" Click="FilterCheckBox_Click" Margin="0,0,0,6"
                                      ToolTip="Show/hide offline devices in the results." />
                            <CheckBox x:Name="ShowCachedCheck" Content="Show Cached Devices" FontSize="11" IsChecked="True"
                                      Foreground="{DynamicResource TextBrush}" Click="FilterCheckBox_Click" Margin="0,0,0,8"
                                      ToolTip="Show/hide cached offline devices in the results." />
                            <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,8"/>
                            <CheckBox x:Name="PeriodicScanCheck" Content="Periodic Rescan" FontSize="11" IsChecked="False"
                                      Foreground="{DynamicResource TextBrush}" Checked="PeriodicScanCheck_Changed" Unchecked="PeriodicScanCheck_Changed" Margin="0,0,0,6"
                                      ToolTip="Enable periodic automatic rescanning." />
                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="Every " FontSize="11" VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}" />
                                <ComboBox x:Name="PeriodicIntervalCombo" Width="75" Height="22" FontSize="11"
                                          VerticalContentAlignment="Center" SelectedIndex="1"
                                          IsEnabled="{Binding IsChecked, ElementName=PeriodicScanCheck}">
                                    <ComboBoxItem Content="1 min" Tag="1" />
                                    <ComboBoxItem Content="5 min" Tag="5" />
                                    <ComboBoxItem Content="10 min" Tag="10" />
                                    <ComboBoxItem Content="30 min" Tag="30" />
                                    <ComboBoxItem Content="60 min" Tag="60" />
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Scan / Clear / Export -->
                <Button x:Name="StartButton" Content="Scan" Width="76" Height="24"
                        Background="#0078D4" Foreground="White" FontWeight="SemiBold"
                        FontSize="11" BorderThickness="0"
                        Click="StartButton_Click" VerticalAlignment="Bottom"
                        Margin="0,0,5,0" />

                <Button Content="Clear"  Width="50" Height="24" FontSize="11"
                        Click="ClearButton_Click" VerticalAlignment="Bottom"
                        Margin="0,0,5,0" />

                <Button Content="Export" Width="50" Height="24" FontSize="11"
                        Click="ExportButton_Click" VerticalAlignment="Bottom"
                        Margin="0,0,5,0" />

                <Button x:Name="ColumnsButton" Content="Columns" Width="72" Height="24" FontSize="11"
                        Click="ColumnsButton_Click" VerticalAlignment="Bottom"
                        Margin="0,0,5,0" />

                <!-- Find button + Popup -->
                <Button x:Name="FindButton" Content="Find" Width="44" Height="24"
                        FontSize="11" Click="FindButton_Click"
                        VerticalAlignment="Bottom" ToolTip="Find / search results (Ctrl+F)" />

                <!-- The search popup anchors to FindButton -->
                <Popup x:Name="FindPopup"
                       PlacementTarget="{Binding ElementName=FindButton}"
                       Placement="Bottom"
                       StaysOpen="True"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Padding="8,6"
                            CornerRadius="2">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" Opacity="0.25"
                                              ShadowDepth="2" Direction="270" />
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox x:Name="SearchBox"
                                     Width="200" Height="22" Padding="5,2"
                                     FontSize="11" VerticalContentAlignment="Center"
                                     TextChanged="SearchBox_TextChanged"
                                     KeyDown="SearchBox_KeyDown"
                                     ToolTip="Enter = next  Shift+Enter = previous  Esc = close" />
                            <Button Content="^" Width="24" Height="22" FontSize="12"
                                    Click="SearchPrev_Click" Margin="4,0,2,0"
                                    ToolTip="Previous match (Shift+Enter)" />
                            <Button Content="v" Width="24" Height="22" FontSize="12"
                                    Click="SearchNext_Click" Margin="0,0,6,0"
                                    ToolTip="Next match (Enter)" />
                            <TextBlock x:Name="SearchStatus" FontSize="10"
                                       VerticalAlignment="Center" MinWidth="60"
                                       Foreground="{DynamicResource HeaderTextBrush}" />
                        </StackPanel>
                    </Border>
                </Popup>

            </StackPanel>
        </Border>

        <!-- Results grid -->
        <DataGrid Grid.Row="1" x:Name="ResultsGrid"
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  BorderThickness="0"
                  Sorting="ResultsGrid_Sorting"
                  Foreground="{DynamicResource GridTextBrush}"
                  Background="{DynamicResource GridBackgroundBrush}"
                  RowBackground="{DynamicResource GridBackgroundBrush}"
                  AlternatingRowBackground="{DynamicResource GridAlternatingBrush}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                  HeadersVisibility="Column"
                  SelectionMode="Extended"
                  ColumnHeaderHeight="26"
                  RowHeight="22">

            <!-- Column header with sort arrow indicator -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"      Value="{DynamicResource GridHeaderBrush}" />
                    <Setter Property="Foreground"      Value="{DynamicResource GridTextBrush}" />
                    <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="Padding"         Value="8,0,4,0" />
                    <Setter Property="FontSize"        Value="11" />
                    <Setter Property="FontWeight"      Value="SemiBold" />
                    <Setter Property="Cursor"          Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridColumnHeader">
                                <Grid>
                                    <Border x:Name="HeaderBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" x:Name="SortArrow"
                                                       Text="" FontSize="10" Foreground="#0078D4"
                                                       VerticalAlignment="Center" Margin="2,0,4,0"
                                                       Visibility="Collapsed" />
                                        </Grid>
                                    </Border>
                                    <Thumb x:Name="PART_LeftHeaderGripper"
                                           HorizontalAlignment="Left"
                                           Width="6"
                                           Background="Transparent"
                                           Cursor="SizeWE">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="Transparent" Width="{TemplateBinding Width}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                    <Thumb x:Name="PART_RightHeaderGripper"
                                           HorizontalAlignment="Right"
                                           Width="6"
                                           Background="Transparent"
                                           Cursor="SizeWE">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="Transparent" Width="{TemplateBinding Width}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="SortDirection" Value="Ascending">
                                        <Setter TargetName="SortArrow"    Property="Visibility" Value="Visible" />
                                        <Setter TargetName="SortArrow"    Property="Text"       Value="^" />
                                        <Setter TargetName="HeaderBorder" Property="Background"
                                                Value="{DynamicResource InputBackgroundBrush}" />
                                    </Trigger>
                                    <Trigger Property="SortDirection" Value="Descending">
                                        <Setter TargetName="SortArrow"    Property="Visibility" Value="Visible" />
                                        <Setter TargetName="SortArrow"    Property="Text"       Value="v" />
                                        <Setter TargetName="HeaderBorder" Property="Background"
                                                Value="{DynamicResource InputBackgroundBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="HeaderBorder" Property="Background"
                                                Value="{DynamicResource GridAlternatingBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <!-- Cell style -->
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding"         Value="8,0,4,0" />
                    <Setter Property="FontSize"        Value="11" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0078D4" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <!-- Row style with search-match highlight -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSearchMatch}" Value="True">
                            <Setter Property="Background" Value="#1A0078D4" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="State" Width="80" SortMemberPath="StateLabel">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Padding="8,0,4,0" VerticalAlignment="Center" Text="{Binding StateLabel}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Gray" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StateLabel}" Value="Live">
                                                <Setter Property="Foreground" Value="#107C41" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StateLabel}" Value="Cached">
                                                <Setter Property="Foreground" Value="Gray" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StateLabel}" Value="Offline">
                                                <Setter Property="Foreground" Value="#D83B01" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Custom Name"
                                    Binding="{Binding CustomName, UpdateSourceTrigger=PropertyChanged}"
                                    Width="170"
                                    SortMemberPath="CustomName" />
                <DataGridTemplateColumn Header="First Seen" Width="145" SortMemberPath="FirstSeen">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <local:HighlightTextBlock Text="{Binding FirstSeen, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                      SearchTerm="{Binding SearchTerm}"
                                                      Padding="8,0,4,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Last Seen" Width="145" SortMemberPath="LastSeen">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <local:HighlightTextBlock Text="{Binding LastSeen, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                      SearchTerm="{Binding SearchTerm}"
                                                      Padding="8,0,4,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="IP Address" Width="115" SortMemberPath="IPAddress">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <local:HighlightTextBlock Text="{Binding IPAddress}"
                                                      SearchTerm="{Binding SearchTerm}"
                                                      Padding="8,0,4,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Hostname" Width="200" SortMemberPath="Hostname">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <local:HighlightTextBlock Text="{Binding Hostname}"
                                                      SearchTerm="{Binding SearchTerm}"
                                                      Padding="8,0,4,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="MAC Address" Width="130" SortMemberPath="MACAddress">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <local:HighlightTextBlock Text="{Binding MACAddress}"
                                                      SearchTerm="{Binding SearchTerm}"
                                                      Padding="8,0,4,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Vendor" Width="185" SortMemberPath="Vendor">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <local:HighlightTextBlock Text="{Binding Vendor}"
                                                      SearchTerm="{Binding SearchTerm}"
                                                      Padding="8,0,4,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Open Ports" Width="100" SortMemberPath="OpenPortsString">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <local:HighlightTextBlock Text="{Binding OpenPortsString}"
                                                      SearchTerm="{Binding SearchTerm}"
                                                      Padding="8,0,4,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="IPv6 Address" Width="220" SortMemberPath="IPv6Address">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <local:HighlightTextBlock Text="{Binding IPv6Address}"
                                                      SearchTerm="{Binding SearchTerm}"
                                                      Padding="8,0,4,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource BackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           Text="Ready" FontSize="11"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="AdminWarningText" Text="⚠️ Standard User (Limited performance)" 
                               Foreground="#FFB300" FontSize="11" Margin="0,0,10,0" VerticalAlignment="Center" Visibility="Collapsed" />
                    <Button x:Name="RestartAdminBtn" Content="Restart as Admin" FontSize="10" Padding="6,1"
                            Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" 
                            Foreground="{DynamicResource TextBrush}" Click="RestartAdminBtn_Click" Visibility="Collapsed" Margin="0,0,15,0" />
                    <TextBlock FontSize="10" VerticalAlignment="Center" Foreground="{DynamicResource HeaderTextBrush}">
                        <Hyperlink x:Name="VersionLink"
                                   NavigateUri="https://github.com/micahp2/NetworkScanner"
                                   RequestNavigate="VersionLink_RequestNavigate"
                                   Foreground="{DynamicResource HeaderTextBrush}">
                            <Run x:Name="VersionText" Text="v1.0.8" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
