<Window x:Class="NetworkScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Scanner" Height="800" Width="1400" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Foreground="{StaticResource TextBrush}"
        Background="{StaticResource PanelBrush}">
    <Grid Background="{StaticResource PanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="120" />
            <RowDefinition Height="*" MinHeight="300" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Input Panel -->
        <Border Grid.Row="0" Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="15">
            <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                <!-- Row 1: IP Ranges and Ports -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <StackPanel VerticalAlignment="Top" Margin="0,0,20,0">
                        <TextBlock Text="IP Ranges:" FontWeight="Bold" Margin="0,0,0,5" FontSize="11" Foreground="{StaticResource HeaderTextBrush}" />
                        <TextBox x:Name="RangesText" Width="250" Height="32" Padding="8" 
                                 Text="192.168.2.0/24" VerticalContentAlignment="Center" FontSize="10"
                                 Background="{StaticResource InputBackgroundBrush}" Foreground="{StaticResource InputTextBrush}" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Top" Margin="0,0,20,0">
                        <TextBlock Text="Ports:" FontWeight="Bold" Margin="0,0,0,5" FontSize="11" Foreground="{StaticResource HeaderTextBrush}" />
                        <TextBox x:Name="PortsText" Width="300" Height="32" Padding="8"
                                 Text="22,53,80,443,3306,8080,8443" VerticalContentAlignment="Center" FontSize="10"
                                 Background="{StaticResource InputBackgroundBrush}" Foreground="{StaticResource InputTextBrush}" />
                    </StackPanel>

                    <Button x:Name="StartButton" Content="▶ Start Scan" Width="120" Height="40" 
                            Background="#0078D4" Foreground="White" FontWeight="Bold" 
                            Click="StartButton_Click" Cursor="Hand" VerticalAlignment="Bottom" Margin="0,0,10,0"
                            Padding="8,8" />
                    <Button Content="Clear" Width="100" Height="40" Click="ClearButton_Click" 
                            VerticalAlignment="Bottom" Margin="0,0,10,0" Padding="8,8" />
                    <Button Content="Export CSV" Width="120" Height="40" Click="ExportButton_Click" 
                            VerticalAlignment="Bottom" Padding="8,8" />
                </StackPanel>

                <!-- Row 2: Options -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Options:" FontWeight="Bold" Margin="0,0,15,0" FontSize="11" Foreground="{StaticResource HeaderTextBrush}" VerticalAlignment="Center" />
                    <CheckBox x:Name="DnsCheck" Content="DNS" IsChecked="True" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{StaticResource TextBrush}" />
                    <CheckBox x:Name="MacCheck" Content="MAC" IsChecked="True" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{StaticResource TextBrush}" />
                    <CheckBox x:Name="VendorCheck" Content="Vendor" IsChecked="True" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{StaticResource TextBrush}" />
                    <CheckBox x:Name="IPv4Check" Content="IPv4" IsChecked="True" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{StaticResource TextBrush}" />
                    <CheckBox x:Name="IPv6Check" Content="IPv6" IsChecked="False" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Results Grid -->
        <DataGrid Grid.Row="1" x:Name="ResultsGrid" Margin="10" 
                  AutoGenerateColumns="False" CanUserAddRows="False"
                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                  Sorting="ResultsGrid_Sorting" 
                  Foreground="{StaticResource GridTextBrush}"
                  Background="{StaticResource GridBackgroundBrush}"
                  RowBackground="{StaticResource GridAlternatingBrush}"
                  HeadersVisibility="Column">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource GridHeaderBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource GridTextBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="IP Address" Binding="{Binding IPAddress}" Width="130" />
                <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="240" />
                <DataGridTextColumn Header="MAC Address" Binding="{Binding MACAddress}" Width="140" />
                <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" Width="220" />
                <DataGridTextColumn Header="Open Ports" Binding="{Binding OpenPortsString}" Width="130" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText" Text="Ready" Padding="10,5" Foreground="{StaticResource TextBrush}" />
        </StatusBar>
    </Grid>
</Window>
